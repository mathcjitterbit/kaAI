# ─── AWS Credentials ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# ─── OpenSearch ─────────────────────────────────────────────────
# Local: localhost | AWS: your-domain.us-east-1.es.amazonaws.com
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
# Set to "true" when using AWS OpenSearch (HTTPS)
OPENSEARCH_USE_SSL=false

# ─── S3 (document storage) ──────────────────────────────────────
S3_BUCKET=kaai-documents
S3_PREFIX=docs/

# ─── Ingestion source ───────────────────────────────────────────
# "local" uses docs/ folder | "s3" reads from S3_BUCKET
INGEST_SOURCE=local

# ─── Slack ──────────────────────────────────────────────────────
# Get these from https://api.slack.com/apps after creating the app
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
